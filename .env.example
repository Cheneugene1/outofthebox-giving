# Out of the Box Giving — 环境变量

# Demo 模式：不调用真实 AI，使用 mock 数据
# 要使用真实大模型，删除或注释这行，然后填下面的 API Key
DEMO_MODE=true

# AI Provider — 选择大模型提供商
# 可选值: deepseek | openai
AI_PROVIDER=deepseek

# DeepSeek API Key (https://platform.deepseek.com/api_keys)
# DeepSeek 新用户通常有免费额度
# DEEPSEEK_API_KEY=sk-xxx

# OpenAI API Key (仅当 AI_PROVIDER=openai 时需要)
# OPENAI_API_KEY=sk-xxx

# SQLite 数据库文件路径
DATABASE_PATH=./data.db
